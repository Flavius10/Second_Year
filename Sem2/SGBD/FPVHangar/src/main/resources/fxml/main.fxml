<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="850.0" spacing="15.0" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <Label text="Producători (Tabel Părinte)">
        <font><Font name="System Bold" size="16.0" /></font>
    </Label>
    <TableView fx:id="producatorTable" prefHeight="200.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colProdId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colProdNume" prefWidth="250.0" text="Nume Producător" />
            <TableColumn fx:id="colProdTara" prefWidth="200.0" text="Țara Origine" />
        </columns>
    </TableView>

    <Separator prefWidth="200.0" />

    <Label text="Drone FPV (Tabel Copil)">
        <font><Font name="System Bold" size="16.0" /></font>
    </Label>
    <TableView fx:id="dronaTable" prefHeight="250.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDronaId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colDronaModel" prefWidth="200.0" text="Nume Model" />
            <TableColumn fx:id="colDronaGreutate" prefWidth="100.0" text="Greutate (g)" />
            <TableColumn fx:id="colDronaCadru" prefWidth="150.0" text="Tip Cadru" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <TextField fx:id="txtModel" prefWidth="150.0" promptText="Nume Model" />
        <TextField fx:id="txtGreutate" prefWidth="100.0" promptText="Greutate (g)" />
        <TextField fx:id="txtCadru" prefWidth="150.0" promptText="Tip Cadru" />

        <Region HBox.hgrow="ALWAYS" />

        <Button mnemonicParsing="false" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Adaugă" />
        <Button mnemonicParsing="false" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="Modifică" />
        <Button mnemonicParsing="false" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="Șterge" />
    </HBox>

</VBox>