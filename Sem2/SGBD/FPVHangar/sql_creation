-- 1. Creare Tabele

CREATE TABLE Producator (
    id SERIAL PRIMARY KEY,
    nume VARCHAR(100) NOT NULL,
    tara_origine VARCHAR(50)
);

CREATE TABLE Drona (
    id SERIAL PRIMARY KEY,
    nume_model VARCHAR(100) NOT NULL,
    greutate_grame INT NOT NULL,
    tip_cadru VARCHAR(50),
    producator_id INT NOT NULL,
    FOREIGN KEY (producator_id) REFERENCES Producator(id) ON DELETE CASCADE
);

CREATE TABLE Componenta (
    id SERIAL PRIMARY KEY,
    denumire VARCHAR(100) NOT NULL,
    categorie VARCHAR(50)
);

CREATE TABLE Drona_Componenta (
    drona_id INT NOT NULL,
    componenta_id INT NOT NULL,
    PRIMARY KEY (drona_id, componenta_id),
    FOREIGN KEY (drona_id) REFERENCES Drona(id) ON DELETE CASCADE,
    FOREIGN KEY (componenta_id) REFERENCES Componenta(id) ON DELETE CASCADE
);

