<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="grup.controller.CarController"
      prefHeight="400.0" prefWidth="600.0"
      spacing="15" alignment="CENTER_LEFT">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Detalii Masina" textFill="#7f8c8d">
        <font><Font size="14.0" /></font>
    </Label>

    <Label fx:id="denumireMasina" text="Dacia..." textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label fx:id="desciereMasina" text="Descriere..." wrapText="true">
        <font>
            <Font size="16.0" />
        </font>
    </Label>

    <Label fx:id="pretMasina" text="Pret..." textFill="#27ae60">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>

    <Label fx:id="statusMasina" text="Status..." textFill="#e67e22">
        <font>
            <Font name="System Bold" size="16.0" />
        </font>
    </Label>

    <Label text="Comentarii Admin:" textFill="#7f8c8d"/>
    <Label fx:id="comentariiMasina" text="-" textFill="#c0392b" wrapText="true"/>

</VBox>