<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/19"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="grup.controllers.StaffController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="STAFF - Comenzi Active">
        <font><Font name="System Bold" size="18.0" /></font>
    </Label>

    <TableView fx:id="tableOrders" prefHeight="400.0" prefWidth="500.0">
        <columns>
            <TableColumn text="ID" prefWidth="50.0">
                <cellValueFactory><PropertyValueFactory property="id" /></cellValueFactory>
            </TableColumn>
            <TableColumn text="Masa" prefWidth="80.0">
                <cellValueFactory><PropertyValueFactory property="tableId" /></cellValueFactory>
            </TableColumn>
            <TableColumn text="Data" prefWidth="150.0">
                <cellValueFactory><PropertyValueFactory property="date" /></cellValueFactory>
            </TableColumn>
            <TableColumn text="Status" prefWidth="100.0">
                <cellValueFactory><PropertyValueFactory property="status" /></cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>
</VBox>