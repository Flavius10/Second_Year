<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="grup.snipets.controller_example.MainController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Label text="Gestiune Masini" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <TextField fx:id="textSearch" promptText="Cauta dupa nume..." HBox.hgrow="ALWAYS" />
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colModel" prefWidth="200.0" text="Model Masina" />
            <TableColumn fx:id="colPret" prefWidth="100.0" text="Pret (EUR)" />
            <TableColumn fx:id="colStatus" prefWidth="150.0" text="Status" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER" spacing="20.0">
        <Button onAction="#handleOpenAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="ADAUGA" />
        <Button onAction="#handleOpenUpdate" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="MODIFICA" />
        <Button onAction="#handleDelete" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="STERGE" />
    </HBox>

    <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-background-radius: 5;">
        <padding>
            <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
        </padding>

        <Button fx:id="btnPrev" onAction="#handlePrev" text="&lt; Inapoi" />
        <Label fx:id="labelPage" text="Pagina 1 / X">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
            <Button fx:id="btnNext" onAction="#handleNext" text="Inainte &gt;" />

        <Label text=" | Elemente pe pag:" textFill="#7f8c8d" />
        <ComboBox fx:id="comboPageSize" prefWidth="70.0" />
    </HBox>

</VBox>